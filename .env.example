# ORQ.AI — LLM gateway (OpenAI-compatible router)
ORQ_API_KEY=orq-...
ORQ_BASE_URL=https://api.orq.ai/v3/router

# Modellen (via ORQ router)
SPAN_MODEL_MAIN=aws/eu.anthropic.claude-sonnet-4-5-20250929-v1:0
SPAN_MODEL_LIGHT=aws/eu.anthropic.claude-haiku-4-5-20251001-v1:0
SPAN_EMBED_MODEL=openai/text-embedding-3-large
SPAN_EMBED_DIMS=1024

# Neo4j Desktop — brein (read/write)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
BRAIN_DB=span-brain

# Web-UI: token voor toegang van buiten localhost. Leeg = alleen lokaal.
# Voor een server: zet hier een lang willekeurig wachtwoord.
SPAN_AUTH_TOKEN=

# Toegewijde sleutel om Microsoft-SSO-sessiecookies te ondertekenen. Verplicht
# in web-login-modus; GEEN hergebruik van SPAN_AUTH_TOKEN (aparte trust-grens).
# Genereer bv. met: python -c "import secrets;print(secrets.token_urlsafe(48))"
SPAN_SESSION_SECRET=

# Publieke https-URL waarop LO van buiten bereikbaar is (achter reverse proxy).
# Nodig voor OAuth-redirects zoals de MCP-login (bijv. Asana), zodat de callback
# een correcte https-URL is i.p.v. de interne http-host. Leeg = val terug op de
# request-URL (prima lokaal). Voorbeeld: https://agent.famspaan.nl
SPAN_PUBLIC_URL=

# Optioneel: productiedata (alleen-lezen). Leeg = uitgeschakeld.
WORK_NEO4J_URI=
WORK_NEO4J_USER=
WORK_NEO4J_PASSWORD=
WORK_DB=

# Stem (TTS) — faalketen: ElevenLabs (cloud) -> XTTS (lokale GPU) -> Piper (CPU).
# ElevenLabs = beste kwaliteit, maar de uitgesproken tekst verlaat de server
# (VS-verwerking) — bewuste keuze van de beheerder. Leeg = alles lokaal.
ELEVENLABS_API_KEY=
# Optioneel: specifieke voice/model (default: Rachel + eleven_multilingual_v2)
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=
# Lokale XTTS-GPU-service (bv. http://xtts:8001). Leeg = Piper.
SPAN_XTTS_URL=
